{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:custom_name",
    "cases": [
      {
        "when": "Ignore Blockstate",
        "model": {
          "type": "minecraft:model",
          "model": "inworldrecipes:item/condition/ignore_blockstate"
        }
      },
      {
        "when": "Weather: Rain",
        "model": {
          "type": "minecraft:model",
          "model": "inworldrecipes:item/condition/weather_rain"
        }
      },
      {
        "when": "Weather: Thunder",
        "model": {
          "type": "minecraft:model",
          "model": "inworldrecipes:item/condition/weather_thunder"
        }
      },
      {
        "when": "Weather: Snow",
        "model": {
          "type": "minecraft:model",
          "model": "inworldrecipes:item/condition/weather_snow"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "inworldrecipes:item/condition"
    }
  }
}
